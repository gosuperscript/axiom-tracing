{
    "name": "gosuperscript/axiom-tracing",
    "description": "Opt-in execution tracing for gosuperscript/axiom",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "gosuperscript/axiom": "0.x-dev",
        "gosuperscript/monads": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "2.1.45",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Superscript\\Axiom\\Tracing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Superscript\\Axiom\\Tracing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:types": "vendor/bin/phpstan analyse --level=max src tests",
        "test:unit": "vendor/bin/phpunit",
        "test": [
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
